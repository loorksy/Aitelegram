NODE_ENV=development
PORT=3010
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/smart_generator?schema=public
LOG_LEVEL=info
MASTER_BOT_TOKEN=your-telegram-master-bot-token
OPENAI_API_KEY=your-openai-api-key
ENCRYPTION_KEY=replace-with-32-byte-base64-key
MEDIA_MAX_FILE_MB=10
STORAGE_MAX_SIZE_MB=200
MEDIA_CLEANUP_DAYS=30
